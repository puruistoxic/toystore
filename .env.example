# Copy to `.env` on the server (same directory as docker-compose.yml):
#   cp .env.example .env && nano .env
# Never commit `.env` — it holds secrets.

# --- Frontend (baked in at `docker compose build` time) ---
REACT_APP_API_URL=/api
# Canonical / Open Graph base URL (no trailing slash). Use your live HTTPS origin so WhatsApp & Facebook show correct previews.
REACT_APP_SITE_URL=https://khandelwaltoystore.com
# Optional: richer Facebook / Instagram link insights
# REACT_APP_FACEBOOK_APP_ID=
# Optional: twitter:site handle, e.g. @YourStore
# REACT_APP_TWITTER_SITE=
REACT_APP_TIMEZONE=Asia/Kolkata
# Optional: TinyMCE for admin rich text (get a key at https://www.tiny.cloud/)
REACT_APP_TINYMCE_API_KEY=
# Optional analytics
REACT_APP_GOOGLE_ANALYTICS_ID=

# --- Reverse proxy (Nginx Proxy Manager / similar) ---
PUBLIC_DOMAIN=toystore.example.com
# www → apex redirect (edit hostnames to match PUBLIC_DOMAIN)
NGINX_PROXY_REDIRECTS=www.toystore.example.com:https://toystore.example.com

# --- API (runtime) ---
NODE_ENV=production
PORT=3001
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32
ADMIN_DEFAULT_PASSWORD=change-me-strong-password

# MySQL (must live in THIS file next to docker-compose.yml — not server/.env only)
# If the password contains # or $, use single quotes: MYSQL_PASSWORD='my#secret$pass'
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=toystoredb
MYSQL_USER=toystore
MYSQL_PASSWORD=change-me-database-password
# Optional: set to a second host if primary fails (non-production defaults differ). Empty = no fallback.
# MYSQL_FALLBACK_HOST=

# SMTP (ZeptoMail / other)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Optional: from header for notification emails (ZeptoMail may require a verified sender)
# SMTP_FROM="DigiDukaanLive" <notifications@your-verified-domain.com>
# Lead alerts for product WhatsApp enquiries (falls back to company_settings.email in DB)
ADMIN_ALERT_EMAIL=

# Copy to `.env` on the server (same directory as docker-compose.yml):
#   cp .env.example .env && nano .env
# Never commit `.env` — it holds secrets.

# --- Frontend (baked in at `docker compose build` time) ---
REACT_APP_API_URL=/api
# Canonical / Open Graph base URL (no trailing slash). Use your live HTTPS origin so WhatsApp & Facebook show correct previews.
REACT_APP_SITE_URL=https://digidukaanlive.com
# Optional: richer Facebook / Instagram link insights
# REACT_APP_FACEBOOK_APP_ID=
# Optional: twitter:site handle, e.g. @YourStore
# REACT_APP_TWITTER_SITE=
REACT_APP_TIMEZONE=Asia/Kolkata
# Optional: TinyMCE for admin rich text (get a key at https://www.tiny.cloud/)
REACT_APP_TINYMCE_API_KEY=
# Optional analytics
REACT_APP_GOOGLE_ANALYTICS_ID=

# --- Reverse proxy (Nginx Proxy Manager / similar) ---
PUBLIC_DOMAIN=toystore.example.com
# www → apex redirect (edit hostnames to match PUBLIC_DOMAIN)
NGINX_PROXY_REDIRECTS=www.toystore.example.com:https://toystore.example.com

# --- API (runtime) ---
NODE_ENV=production
PORT=3001
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32
ADMIN_DEFAULT_PASSWORD=change-me-strong-password

# MySQL (must live in THIS file next to docker-compose.yml — not server/.env only)
# If the password contains # or $, use single quotes: MYSQL_PASSWORD='my#secret$pass'
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=toystoredb
MYSQL_USER=toystore
MYSQL_PASSWORD=change-me-database-password
# Optional: set to a second host if primary fails (non-production defaults differ). Empty = no fallback.
# MYSQL_FALLBACK_HOST=

# SMTP (ZeptoMail / other)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Optional: from header for notification emails (ZeptoMail may require a verified sender)
# SMTP_FROM="DigiDukaanLive" <notifications@your-verified-domain.com>
# Lead alerts for product WhatsApp enquiries (falls back to company_settings.email in DB)
ADMIN_ALERT_EMAIL=

# --- Razorpay (Standard Web Checkout) ---
# Get your keys from https://dashboard.razorpay.com/app/keys
# Server-side credentials (read by the Express API). KEY_SECRET MUST NEVER reach the browser.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Public key for the React (CRA) frontend bundle. This is the SAME value as RAZORPAY_KEY_ID
# (public test/live key id) — it is browser-safe and is the only Razorpay value compiled
# into the frontend. Never set REACT_APP_RAZORPAY_KEY_SECRET — secrets stay on the server.
REACT_APP_RAZORPAY_KEY_ID=
# Webhook secret. Generate a strong random string (e.g. openssl rand -hex 32) and paste
# the SAME value into Razorpay Dashboard → Settings → Webhooks → Secret. Required for the
# POST /api/payments/webhook endpoint to accept events. Strongly recommended in production
# so payment.captured events are recorded even if the customer's browser closes the popup.
RAZORPAY_WEBHOOK_SECRET=

# --- Customer (storefront) auth ---
# Distinct from admin JWT_SECRET. Generate: openssl rand -base64 48
CUSTOMER_JWT_SECRET=
CUSTOMER_JWT_TTL=30d
# Public origin used for magic-link / OAuth redirect URLs (no trailing slash).
MAGIC_LINK_BASE_URL=https://digidukaanlive.com
MAGIC_LINK_TTL_MIN=15

# --- Google OAuth (optional; leave blank to hide the "Sign in with Google" button) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://digidukaanlive.com/api/customer/auth/google/cb

# --- WhatsApp OTP via Zavu (https://zavu.dev) — optional ---
# Default provider is zavu when an API key is set. Set to none to disable.
WHATSAPP_OTP_PROVIDER=zavu
# Prefer ZAVUDEV_API_KEY (Zavu dashboard); WHATSAPP_OTP_API_KEY is accepted as an alias.
ZAVUDEV_API_KEY=
WHATSAPP_OTP_API_KEY=
# Zavu sender profile id (optional — uses project default if empty)
WHATSAPP_OTP_SENDER=
# ZAVU_SENDER_ID=
# For new WhatsApp conversations you need a Meta-approved template in Zavu.
# Template body should use {{1}} for the 6-digit OTP (AUTHENTICATION category recommended).
WHATSAPP_OTP_TEMPLATE_ID=
# Optional JSON for extra template variables, e.g. {"2":"DigiDukaanLive"} for {{2}}
# WHATSAPP_OTP_TEMPLATE_VARS=
# WHATSAPP_OTP_BRAND_NAME=DigiDukaanLive
# WHATSAPP_OTP_DEFAULT_CC=91
